# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# large generated seed files
/seeds/protondb-top-10k.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# cursor / editor
.cursor/

# turbo
.turbo

# superpowers visual brainstorming (local mockups, auto-generated)
.superpowers/

# worktrees for isolated execution
.worktrees/

# Local Next.js dev server logs from background runs / monitors
.next-dev-*.log
.next-dev-*.out.log
.next-dev-*.err.log

# Local AI / Claude / agent session artifacts (worktrees, settings, temp) when running inside workspace
.claude/
